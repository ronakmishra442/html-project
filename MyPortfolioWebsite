  0 10px 30px rgba(0,0,0,.08);
}

.contact-form-card h2{
  margin-bottom:25px;
  color:#2563eb;
}

.form-group{
  margin-bottom:20px;
}

.form-group label{
  display:block;
  margin-bottom:8px;
  font-weight:600;
}

.form-group input,
.form-group textarea{
  width:100%;
  padding:14px;
  border:1px solid #dbeafe;
  border-radius:10px;
  outline:none;
  transition:.3s;
}

.form-group input:focus,
.form-group textarea:focus{
  border-color:#2563eb;
  box-shadow:
  0 0 0 4px rgba(37,99,235,.1);
}

/* ==========================
   CONTACT INFO
========================== */

.contact-info{
  display:flex;
  flex-direction:column;
  gap:20px;
}

.contact-info .info-card,
.social-card{
