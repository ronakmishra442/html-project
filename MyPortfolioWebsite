  height:100%;
  background:#2563eb;
}

.timeline-item{
  position:relative;
  padding-left:70px;
  margin-bottom:40px;
}

.timeline-item::before{
  content:"";
  position:absolute;
  left:10px;
  top:10px;
  width:24px;
  height:24px;
  background:#2563eb;
  border-radius:50%;
  border:4px solid white;
}

.timeline-content{
