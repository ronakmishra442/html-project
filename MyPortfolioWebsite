/* ==========================
   CONTACT SECTION
========================== */

.contact-section{
  padding:100px 0;
}

.contact-grid{
  display:grid;
  grid-template-columns:2fr 1fr;
  gap:40px;
}

/* ==========================
   CONTACT FORM
========================== */

.contact-form-card{
  background:white;
  padding:40px;
  border-radius:20px;
