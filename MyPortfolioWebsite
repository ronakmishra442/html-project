/* ==========================
   RESPONSIVE DESIGN
========================== */

@media(max-width:992px){

  .hero-container{
    grid-template-columns:1fr;
    text-align:center;
  }

  .hero-buttons{
    justify-content:center;
  }

  .about-grid{
    grid-template-columns:1fr;
    text-align:center;
  }

  .contact-grid{
    grid-template-columns:1fr;
  }

  .image-box{
    width:280px;
    height:280px;
  }

}

@media(max-width:768px){

  .navbar .container{
    flex-direction:column;
    gap:20px;
  }

  .nav-links{
    flex-wrap:wrap;
    justify-content:center;
    gap:15px;
  }

  .hero-content h1{
    font-size:2.8rem;
  }

  .page-hero h1{
    font-size:2.4rem;
  }

  .section-title h2{
    font-size:2rem;
  }

  .cta h2,
  .download-resume h2{
    font-size:2rem;
  }

}

@media(max-width:576px){

  .container{
    width:92%;
  }

  .hero{
    padding:60px 0;
  }

  .hero-content h1{
    font-size:2.2rem;
  }

  .hero-content h2{
    font-size:1.1rem;
  }

  .page-hero{
    padding:90px 0 60px;
  }

  .page-hero h1{
    font-size:2rem;
  }

  .btn{
    width:100%;
    text-align:center;
  }

  .project-buttons{
    flex-direction:column;
  }

  .timeline-item{
    padding-left:55px;
  }

  .timeline::before{
    left:15px;
  }

  .timeline-item::before{
    left:4px;
  }

}
