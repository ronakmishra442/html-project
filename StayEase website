<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

html{
    scroll-behavior:smooth;
}

body{
    background:#ffffff;
    color:#222;
}

.navbar{
    width:100%;
    position:fixed;
    top:0;
    left:0;
    z-index:1000;

    display:flex;
    justify-content:space-between;
    align-items:center;

    padding:18px 8%;

    background:rgba(255,255,255,0.9);
    backdrop-filter:blur(12px);

    box-shadow:0 2px 20px rgba(0,0,0,0.08);
}

.logo{
    font-size:28px;
    font-weight:700;
    color:#ff385c;
    display:flex;
    align-items:center;
    gap:10px;
}

.search-bar{
    display:flex;
    align-items:center;
    background:#fff;
    border-radius:50px;
    overflow:hidden;
    box-shadow:0 5px 15px rgba(0,0,0,0.08);
}

.search-bar input{
    border:none;
    outline:none;
    padding:12px 20px;
    width:280px;
}

.search-bar button{
    border:none;
    background:#ff385c;
    color:#fff;
    padding:12px 18px;
    cursor:pointer;
}

nav ul{
    display:flex;
    list-style:none;
    gap:30px;
}

nav ul li a{
    text-decoration:none;
    color:#222;
    font-weight:500;
    transition:0.3s;
}

nav ul li a:hover{
    color:#ff385c;
}

.profile{
    width:45px;
    height:45px;
    border-radius:50%;
    background:#f2f2f2;

    display:flex;
    align-items:center;
    justify-content:center;

    cursor:pointer;
    transition:0.3s;
}

.profile:hover{
    background:#ff385c;
    color:#fff;
}


.hero{
    height:100vh;
    background:url("https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=1600")
    center/cover no-repeat;

    position:relative;

    display:flex;
    align-items:center;
    justify-content:center;
}

.overlay{
    position:absolute;
    inset:0;
    background:rgba(0,0,0,0.45);
}

.hero-content{
    position:relative;
    z-index:2;
    text-align:center;
    color:white;
    width:90%;
}

.hero{
    height: 100vh;
}

.hero-content h1{
     font-size:70px;
    margin-bottom:20px; 
    font-size: 5rem;
    font-weight: 700;
    line-height: 1.1;
    text-shadow: 0 5px 20px rgba(0,0,0,0.4);
} 


.hero-content p{
    max-width:700px;
    margin:auto;
    margin-bottom:40px;
    font-size:18px;
}


.booking-box{
    background:rgba(255,255,255,0.18);
    backdrop-filter:blur(15px);

    border:1px solid rgba(255,255,255,0.3);

    padding:25px;
    border-radius:20px;

    display:grid;
    grid-template-columns:repeat(5,1fr);
    gap:15px;

    max-width:1100px;
    margin:auto;
}

.field{
    display:flex;
    flex-direction:column;
    text-align:left;
}

.field label{
    font-size:14px;
    margin-bottom:8px;
    color:#fff;
}

.field input{
    padding:12px;
    border:none;
    border-radius:10px;
    outline:none;
}

.search-btn{
    border:none;
    border-radius:12px;
    background:#ff385c;
    color:white;
    font-size:16px;
    font-weight:600;
    cursor:pointer;
    transition:0.3s;
}

.search-btn:hover{
    transform:translateY(-3px);
}

section h2{
    text-align:center;
    font-size:40px;
    margin-bottom:40px;
}


.categories{
    padding:90px 8%;
}

.category-wrapper{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(130px,1fr));
    gap:20px;
}

.category-card{
    background:#fff;
    padding:25px;
    border-radius:20px;

    text-align:center;

    box-shadow:0 10px 25px rgba(0,0,0,0.08);

    transition:0.3s;
}

.category-card:hover{
    transform:translateY(-8px);
}

.category-card i{
    font-size:30px;
    color:#ff385c;
    margin-bottom:10px;
}

.category-card span{
    display:block;
    font-weight:500;
}

.listings{
    padding:90px 8%;
    background:#fafafa;
}

.listing-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:30px;
}

.listing-card{
    background:#fff;
    border-radius:20px;
    overflow:hidden;

    position:relative;

    transition:0.4s;

    box-shadow:0 10px 30px rgba(0,0,0,0.08);
}

.listing-card:hover{
    transform:translateY(-10px);
}

.listing-card img{
    width:100%;
    height:260px;
    object-fit:cover;
    transition:0.5s;
}

.listing-card:hover img{
    transform:scale(1.08);
}

.heart{
    position:absolute;
    top:15px;
    right:15px;

    width:40px;
    height:40px;
    background:white;

    border-radius:50%;

    display:flex;
    align-items:center;
    justify-content:center;

    cursor:pointer;
}

.card-content{
    padding:20px;
}

.top{
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.top span{
    color:#ff385c;
    font-weight:600;
}

.card-content p{
    color:#666;
    margin:10px 0;
}

.card-content h4{
    color:#222;
}



.destinations{
    padding:90px 8%;
}

.destination-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.destination-card{
    overflow:hidden;
    border-radius:20px;
    position:relative;
    cursor:pointer;
}

.destination-card img{
    width:100%;
    height:350px;
    object-fit:cover;
    transition:0.5s;
}

.destination-c{
    overflow:hidden;
    border-radius:20px;
    position:relative;
    cursor:pointer;
        transition:0.3s;


}

.destination-c img{
    width:2000px;
    height:900px;
    object-fit:cover;
    transition:0.5s;
 

        padding: 30px;
}

.destination-card:hover img{
    transform:scale(1.1);
}

.destination-card h3{
    position:absolute;
    bottom:20px;
    left:20px;

    color:white;
    font-size:28px;
}

.destination-c:hover img{
    transform:scale(1.1);
}

.destination-c h3{
    position:absolute;
    /* bottom:20px; */
    left:20px;

    color:white;
    font-size:28px;
}

.host-banner{
    padding:120px 8%;
}

.host-content{
    background:url("https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=1600")
