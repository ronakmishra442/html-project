        </div>
    </div>
</div>

<style>
*{
    margin:0;
    padding:0;
    font-family: 'Poppins', sans-serif;
    box-sizing: border-box;
}

body{
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #1e1e1e;
}

/* CARD */
.card{
    width: 420px; 
    height: 700px;
    padding: 30px 25px;
    border-radius: 20px;
    background: linear-gradient(135deg,#1f7a6d,#6a5acd);
    display: flex;
    flex-direction: column;
    align-items: center;
}

/* SEARCH BAR */
.search{
    width: 100%;
    display: flex;
    gap: 10px;
}

.search input{
    flex: 1;
    padding: 16px;
    border: none;
    outline: none;
    border-radius: 20px;
}

.search-icon{
    width: 50px;    
    height: 50px;
    background-color: aliceblue;
    border-radius: 50%;
    padding: 10px;
    cursor: pointer;
}

/* WEATHER CENTER */
.weather{
    margin-top: 40px;
    text-align: center;
}

.weather-icon{
    width: 140px;
}

.temp{
    font-size: 50px;
    color: white;
    margin-top: 10px;
}

.city{
    font-size: 40px;
    color: white;
}

/* DETAILS (BOTTOM) */
.details{
    width: 100%;
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    padding: 30px 10px 10px;
}

.col{
    display: flex;
    align-items: center;
    gap: 12px;
    color: white;
}

.col img{
    width: 40px;
}

.value{
    font-size: 18px;
    font-weight: 600;
}

.label{
    font-size: 14px;
    opacity: 0.8;
}
.weather h1{
    margin-top: 80px;
}
.error{
    text-align: center;
}
</style>
</head>

